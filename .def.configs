Core : section
{
	PIT : choice
	{
		name = "PIT Frequency"
		cmd = "-DPIT="
		default = "250hz"
		options = "100hz=100,250hz=250,500hz=500,1000hz=1000"
	}
}

Console : section
{
	TEXT_MODE : choice
	{
		name = "Text Mode"
		cmd = "-DTEXT_MODE="
		default = "80x25"
		options = "40x25=1,80x25=2,80x50=3"
	}
}
